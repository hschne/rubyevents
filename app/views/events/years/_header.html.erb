<header class="mb-8 md:mb-12">
  <h1 class="title shrink-0">
    <%= title "#{year} Events Calendar" %>
  </h1>

  <div class="mt-2 border-b border-gray-200 hotwire-native:hidden">
    <nav aria-label="Event collections" class="flex items-end gap-6 text-sm font-medium">
      <%= link_to "Upcoming", events_path, class: "pb-3 -mb-px border-b-2 border-transparent text-gray-500 hover:text-gray-900 whitespace-nowrap" %>
      <%= link_to "Past", past_events_path, class: "pb-3 -mb-px border-b-2 border-transparent text-gray-500 hover:text-gray-900 whitespace-nowrap" %>
      <%= link_to "Archive", archive_events_path, class: "pb-3 -mb-px border-b-2 border-transparent text-gray-500 hover:text-gray-900 whitespace-nowrap" %>
      <%= link_to "Meetups", meetups_events_path, class: "pb-3 -mb-px border-b-2 border-transparent text-gray-500 hover:text-gray-900 whitespace-nowrap" %>
      <span class="pb-3 border-b-2 border-primary text-primary whitespace-nowrap">Calendar</span>
    </nav>
  </div>
</header>
